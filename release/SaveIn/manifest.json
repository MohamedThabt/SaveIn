{
  "manifest_version": 3,
  "name": "SaveIn",
  "version": "2.0.0",
  "description": "Save LinkedIn posts with metadata, export to Markdown/JSON, and push to Notion.",
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "https://api.notion.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "src/assets/icon16.png",
      "48": "src/assets/icon48.png",
      "128": "src/assets/icon128.png"
    }
  },
  "icons": {
    "16": "src/assets/icon16.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-EsKE1p4_.js"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "resources": [
        "assets/index.ts-EsKE1p4_.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
